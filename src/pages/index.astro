---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/islands/Nav.tsx";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Guide from "../components/Guide.astro";
import Stack from "../components/Stack.astro";
import Dx from "../components/Dx.astro";
import VsNextjs from "../components/VsNextjs.astro";
import Examples from "../components/Examples.astro";
import Proof from "../components/Proof.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Nav client:load />
  <main>
    <Hero />
    <Problem />
    <Guide />
    <Proof />
    <Stack />
    <Dx />
    <VsNextjs variant="teaser" />
    <Examples />
    <CTA />
  </main>
  <Footer />
</Layout>
