---
import Icon from "./Icon.astro";
import { stakes } from "../data/shaka";
---

<section class="section stakes-sec" id="stakes">
  <div class="wrap">
    <div
      class="section-head reveal"
      style="max-width: none; text-align: center; margin-inline: auto; margin-bottom: 44px"
    >
      <span class="eyebrow" style="justify-content: center; display: inline-flex">
        What’s at stake
      </span>
      <h2 style="margin-top: 16px">The difference the stack makes.</h2>
    </div>
    <div class="stakes-grid reveal">
      <div class="stakes-col without">
        <div class="stakes-head">
          <span class="sh-ic">✕</span>
          <h3>Without ShakaStack</h3>
        </div>
        <ul>
          {stakes.without.map((s) => (
            <li><span class="x">✕</span>{s}</li>
          ))}
        </ul>
      </div>
      <div class="stakes-col with">
        <div class="stakes-head">
          <span class="sh-ic ok">🤙</span>
          <h3>With ShakaStack</h3>
        </div>
        <ul>
          {stakes.withStack.map((s) => (
            <li><span class="ok"><Icon name="check" /></span>{s}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
