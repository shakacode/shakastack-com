---
import Icon from "./Icon.astro";
import {
  CONTROL_PLANE_FLOW_LICENSE,
  E2E_ON_RAILS_LICENSE,
  ROR_LICENSE,
  ROR_OSS_VS_PRO,
  ROR_PRO,
  ROR_PRO_LICENSE,
  ROR_SUPPORT,
  SHAKA_BUNDLE_SIZE_NPM_0_0_12,
  SHAKAPACKER_LICENSE,
  SHAKAPERF_LICENSE,
  SHAKAPERF_METHOD,
  SHAKAPERF_NPM_0_1_3,
  SHAKAPERF_PRICING,
  SHAKAPERF_REPORT_GALLERY,
  SHAKAPERF_REPORT_SNAPSHOT,
  MATURITY_SNAPSHOT_DATE,
  maturitySnapshot,
} from "../data/shaka";

const stars = new Intl.NumberFormat("en-US");
---

<section class="section maturity-support" aria-labelledby="maturity-support-title">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">Licenses &amp; support</span>
      <h2 id="maturity-support-title">Clear paths from evaluation to production.</h2>
      <p>
        Public source is not the same as an open-source license. Each path keeps
        its license, evidence, and support route explicit.
      </p>
    </div>

    <section class="maturity-snapshot reveal" aria-labelledby="maturity-snapshot-title">
      <div class="maturity-snapshot-head">
        <div>
          <span class="maturity-card-kicker">Project maturity snapshot</span>
          <h3 id="maturity-snapshot-title">Five public project records, one checked date.</h3>
        </div>
        <p>
          Checked <time datetime={MATURITY_SNAPSHOT_DATE}>{MATURITY_SNAPSHOT_DATE} UTC</time>
          <span aria-hidden="true"> · </span>statically curated
        </p>
      </div>

      <div class="maturity-snapshot-grid" role="list">
        {maturitySnapshot.map((project) => (
          <article
            class={`maturity-snapshot-card maturity-snapshot-card-${project.projectId}`}
            data-project={project.projectId}
            role="listitem"
          >
            <h4>{project.name}</h4>
            <div class="maturity-snapshot-facts">
              <a href={project.recordUrl} target="_blank" rel="noreferrer">
                {project.recordLabel}
              </a>
              <a
                href={project.repositoryMetadataUrl}
                target="_blank"
                rel="noreferrer"
              >
                {stars.format(project.stars)} stars
                <small>GitHub repository metadata JSON</small>
              </a>
              <a
                href={project.repositoryMetadataUrl}
                target="_blank"
                rel="noreferrer"
              >
                Public repo since {project.publicSince}
                <small>GitHub repository metadata JSON</small>
              </a>
            </div>
            {project.note && (
              <a
                class="maturity-snapshot-note"
                href={project.note.sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                {project.note.label}
              </a>
            )}
          </article>
        ))}
      </div>
    </section>

    <div class="maturity-grid">
      <article class="maturity-card reveal">
        <span class="maturity-card-kicker">Community path</span>
        <h3>Open-source foundations</h3>
        <p>
          React on Rails core, Shakapacker, E2E on Rails, and Control Plane Flow
          use open-source licenses. Community help is available through public
          docs, Discussions, and Slack; no service-level agreement is implied.
        </p>
        <div class="maturity-links">
          <a href={ROR_LICENSE} target="_blank" rel="noreferrer">
            React on Rails license <Icon name="arrowUR" />
          </a>
          <a
            href={SHAKAPACKER_LICENSE}
            target="_blank"
            rel="noreferrer"
          >
            Shakapacker license <Icon name="arrowUR" />
          </a>
          <a
            href={E2E_ON_RAILS_LICENSE}
            target="_blank"
            rel="noreferrer"
          >
            E2E on Rails license <Icon name="arrowUR" />
          </a>
          <a
            href={CONTROL_PLANE_FLOW_LICENSE}
            target="_blank"
            rel="noreferrer"
          >
            Control Plane Flow license <Icon name="arrowUR" />
          </a>
          <a href={ROR_SUPPORT} target="_blank" rel="noreferrer">
            Community support routes <Icon name="arrowUR" />
          </a>
        </div>
      </article>

      <article class="maturity-card maturity-card-pro reveal">
        <span class="maturity-card-kicker">Commercial path</span>
        <h3>React on Rails Pro</h3>
        <p>
          React on Rails Pro is commercially licensed. Review the published
          EULA and subscription terms before use; paid subscriptions include
          updates and reasonable maintainer support without implying an SLA.
        </p>
        <div class="maturity-links">
          <a href={ROR_OSS_VS_PRO} target="_blank" rel="noreferrer">
            Compare OSS and Pro <Icon name="arrowUR" />
          </a>
          <a href={ROR_PRO} target="_blank" rel="noreferrer">
            Pro overview <Icon name="arrowUR" />
          </a>
          <a href={ROR_PRO_LICENSE} target="_blank" rel="noreferrer">
            Pro license <Icon name="arrowUR" />
          </a>
        </div>
      </article>

      <article class="maturity-card maturity-card-perf reveal">
        <span class="maturity-card-kicker">Newer proof layer</span>
        <h3>ShakaPerf by artifact</h3>
        <p>
          The repository source uses the ShakaPerf License. Separately, npm
          registry JSON metadata for shaka-perf 0.1.3 and shaka-bundle-size 0.0.12 reports
          MIT. Inspect the exact source or package you plan to use.
        </p>
        <div class="maturity-links">
          <a href={SHAKAPERF_REPORT_SNAPSHOT} target="_blank" rel="noreferrer">
            Report snapshot <Icon name="arrowUR" />
          </a>
          <a href={SHAKAPERF_REPORT_GALLERY} target="_blank" rel="noreferrer">
            Report gallery <Icon name="arrowUR" />
          </a>
          <a href={SHAKAPERF_METHOD} target="_blank" rel="noreferrer">
            Statistical methodology <Icon name="arrowUR" />
          </a>
          <a href={SHAKAPERF_LICENSE} target="_blank" rel="noreferrer">
            Repository source license <Icon name="arrowUR" />
          </a>
          <a href={SHAKAPERF_NPM_0_1_3} target="_blank" rel="noreferrer">
            shaka-perf 0.1.3 registry JSON <Icon name="arrowUR" />
          </a>
          <a
            href={SHAKA_BUNDLE_SIZE_NPM_0_0_12}
            target="_blank"
            rel="noreferrer"
          >
            shaka-bundle-size 0.0.12 registry JSON <Icon name="arrowUR" />
          </a>
          <a href={SHAKAPERF_PRICING} target="_blank" rel="noreferrer">
            Pricing <Icon name="arrowUR" />
          </a>
        </div>
      </article>
    </div>
  </div>
</section>
