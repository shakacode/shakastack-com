---
import Icon from "./Icon.astro";
import GitHubMark from "./GitHubMark.astro";
import {
  roads,
  exodusEvidence,
  tanstackSplit,
  starter,
  perfLead,
  perfColumns,
  perfMatrix,
  perfNote,
  STARTER_REPO,
  STARTER_DEMO,
  RSC_VS_NEXTJS_DOC,
} from "../data/shaka";
---

<section class="section vsnext" id="vs-nextjs">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">Leaving Next.js?</span>
      <h2>The Next.js era is cracking. Two roads out.</h2>
      <p>{exodusEvidence}</p>
    </div>

    <div class="roads reveal">
      {
        roads.map((r) => (
          <div class={`road road-${r.kind}`}>
            <span class="road-label">{r.label}</span>
            <h3>{r.title}</h3>
            <p>{r.body}</p>
            <ul>
              {r.points.map((pt) => (
                <li><Icon name="check" />{pt}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="tanstack-split reveal">
      <div class="ts-head">
        <h3>“TanStack” is two different things.</h3>
        <p>Keep them separate - embrace the client libraries, skip the framework.</p>
      </div>
      <div class="ts-cols">
        {
          tanstackSplit.map((t) => (
            <div class={`ts-card ts-${t.kind}`}>
              <span class="ts-tag">
                <Icon name={t.kind === "embrace" ? "check" : "arrowUR"} />
                {t.kind === "embrace" ? "Embrace" : "Substitute"}
              </span>
              <h4>{t.title}</h4>
              <p>{t.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="perf reveal">
      <div class="perf-lead">
        <h3>{perfLead.title}</h3>
        <p>{perfLead.body}</p>
      </div>
      <div class="cmp-wrap">
        <table class="cmp">
          <thead>
            <tr>
              <th></th>
              {
                perfColumns.map((c, i) => (
                  <th class={i === 0 ? "col-ror" : ""}>{c}</th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              perfMatrix.map((row) => (
                <tr>
                  <th scope="row">{row.feature}</th>
                  {row.cells.map((cell, i) => (
                    <td class={i === 0 ? "col-ror" : ""}>
                      {cell === "no" ? (
                        <span class="cell no" aria-label="Not supported">-</span>
                      ) : (
                        <span class="cell yes" aria-label={cell === "rc" ? "Supported (release candidate)" : "Supported"}>
                          <Icon name="check" />
                          {cell === "rc" && <i class="rc">RC</i>}
                        </span>
                      )}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="cmp-note">{perfNote}</p>
    </div>

    <p class="boundary reveal">
      No Rails and little server-side logic? A JavaScript meta-framework is a
      fine choice, and we'll say so. ShakaStack is for teams who have Rails, or
      want it.
    </p>

    <div class="starter reveal">
      <div class="starter-copy">
        <span class="eyebrow">The proof</span>
        <h3>The official React on Rails × TanStack starter.</h3>
        <p>{starter.blurb}</p>
        <p class="starter-guardrail">{starter.guardrail}</p>
        <div class="starter-actions">
          <a class="btn btn-accent" href={STARTER_REPO} target="_blank" rel="noreferrer">
            <GitHubMark width={16} height={16} /> Get the starter
          </a>
          <a class="btn btn-ghost" href={STARTER_DEMO} target="_blank" rel="noreferrer">
            Live demo <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={RSC_VS_NEXTJS_DOC} target="_blank" rel="noreferrer">
            RSC vs Next.js <Icon name="arrowUR" />
          </a>
        </div>
        <div class="starter-chips">
          {starter.stack.map((s) => <span>{s}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
