---
import type { IconName } from "../data/shaka";
import { ICON_PATHS } from "../lib/iconPaths";

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  set:html={ICON_PATHS[name]}
/>
