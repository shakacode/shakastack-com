---
import StackExplorer from "./islands/StackExplorer.tsx";
import { projects } from "../data/shaka";
---

<section
  class="section"
  id="stack"
  style="background: var(--sand-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line)"
>
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The toolkit</span>
      <h2>Give your agents a proven Rails + React toolkit.</h2>
      <p>
        React on Rails and Shakapacker build. E2E on Rails tests behavior.
        ShakaPerf proves performance and visual stability. Control Plane Flow
        deploys. Every project includes public source or docs an agent can read.
      </p>
    </div>

    <div class="reveal">
      <StackExplorer client:visible projects={projects} />
    </div>
  </div>
</section>
