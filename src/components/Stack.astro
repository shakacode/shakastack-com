---
import StackExplorer from "./islands/StackExplorer.tsx";
import { projects } from "../data/shaka";
---

<section
  class="section"
  id="stack"
  style="background: var(--sand-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line)"
>
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The plan</span>
      <h2>Build → bundle → test → prove → deploy.</h2>
      <p>
        Five phases, five open-source projects - one path from Rails + React
        code to validated production. Tap a layer to see how it moves your app
        forward.
      </p>
    </div>

    <div class="reveal">
      <StackExplorer client:visible projects={projects} />
    </div>
  </div>
</section>
