---
import StackExplorer from "./islands/StackExplorer.tsx";
import { projects } from "../data/shaka";
---

<section
  class="section"
  id="stack"
  style="background: var(--sand-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line)"
>
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The plan</span>
      <h2>Pick the project you need. Keep the rest optional.</h2>
      <p>
        Build, test, prove, and deploy with focused projects you can evaluate
        independently. Open a project to see what it does, how to start, and
        where to read the source and docs.
      </p>
    </div>

    <div class="reveal">
      <StackExplorer client:visible projects={projects} />
    </div>
  </div>
</section>
