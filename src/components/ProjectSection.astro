---
import Icon from "./Icon.astro";
import GitHubMark from "./GitHubMark.astro";
import { phaseStage, type Project } from "../data/shaka";

interface Props {
  project: Project;
  index: number;
}

const { project: p, index: i } = Astro.props;
const flip = i % 2 === 1;
const host = p.url.replace("https://www.", "").replace("https://", "");
const github = p.links.find((l) => l[0] === "GitHub");
const docs = p.links.find((l) => l[0] === "Docs");
---

<section
  class={`proj reveal${flip ? " flip" : ""}`}
  id={`proj-${p.id}`}
  style={`--c: var(--${p.accent}); --cd: var(--${p.accent}-deep)`}
>
  <div class="wrap proj-grid">
    <div class="proj-copy">
      <div class="proj-badge">
        <span class="dot"></span>
        <span class="stage">{phaseStage(p)} · 0{i + 1}</span>
      </div>
      <h2>{p.name}</h2>
      <p class="tagline">{p.tagline}</p>
      <p class="blurb">{p.blurb}</p>
      <div class="benefits">
        {
          p.benefits.map(([title, desc]) => (
            <div class="benefit">
              <span class="tick"><Icon name="check" /></span>
              <div>
                <b>{title}</b>
                <p>{desc}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="proj-actions">
        <a class="btn btn-accent" href={p.url} target="_blank" rel="noreferrer">
          Visit {p.domain} <Icon name="arrowUR" />
        </a>
        {
          github && (
            <a class="btn btn-ghost" href={github[1]} target="_blank" rel="noreferrer">
              <GitHubMark width={15} height={15} /> Source
            </a>
          )
        }
        {
          docs && (
            <a class="link-arrow" href={docs[1]} target="_blank" rel="noreferrer">
              Docs <Icon name="arrow" />
            </a>
          )
        }
      </div>
    </div>

    <div class="proj-visual">
      <div class="proj-logo-slot">
        <span class="glyph"><Icon name={p.icon} /></span>
        <span class="ph">{p.name} logo / screenshot</span>
      </div>
      <div class="term">
        <div class="term-bar">
          <i></i><i></i><i></i>
          <span class="tt">{host} — terminal</span>
        </div>
        <div class="term-body">
          <div class="ln"><span class="pr">$</span><span>{p.install}</span></div>
          {
            p.altInstall && (
              <div class="ln"><span class="pr">$</span><span>{p.altInstall}</span></div>
            )
          }
        </div>
      </div>
      <div class="term-meta">
        {p.links.map(([label]) => <span class="chip">{label.toLowerCase()}</span>)}
      </div>
    </div>
  </div>
</section>
