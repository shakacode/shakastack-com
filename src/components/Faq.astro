---
import type { Faq as FaqItem } from "../data/shaka";

interface Props {
  items: FaqItem[];
  id?: string;
  eyebrow?: string;
  heading?: string;
}

const {
  items,
  id = "faq",
  eyebrow = "Honest answers",
  heading = "Questions you should be asking.",
} = Astro.props;
---

<section class="section faq-sec" id={id}>
  <div class="wrap">
    <div class="section-head reveal" style="max-width: none; text-align: center; margin-inline: auto; margin-bottom: 44px">
      <span class="eyebrow" style="justify-content: center; display: inline-flex">{eyebrow}</span>
      <h2 style="margin-top: 16px">{heading}</h2>
    </div>
    <div class="faq-list reveal">
      {
        items.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
