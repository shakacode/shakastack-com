---
import {
  projects,
  SHAKACODE_URL,
  SHAKACODE_CONTACT,
  GITHUB_ORG,
  GITHUB_SPONSOR,
  AGENT_WORKFLOWS_REPO,
  ALL_DEMOS,
  ROR_PRO,
  ROR_SUPPORT,
} from "../data/shaka";
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/#top">
          <span class="mark">🤙</span>
          <span>ShakaStack</span>
        </a>
        <p class="footer-about">
          ShakaCode projects for building, testing, proving, and deploying
          modern Rails&nbsp;+&nbsp;React applications.
        </p>
      </div>
      <div class="footer-col">
        <h4>Projects</h4>
        {projects.map((p) => (
          <a href={p.url} target="_blank" rel="noreferrer">{p.name}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Explore</h4>
        <a href="/#stack">The Stack</a>
        <a href="/vs-nextjs">vs Next.js</a>
        <a href="/#examples">Examples</a>
        <a href={ALL_DEMOS} target="_blank" rel="noreferrer">All demos</a>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <a href={GITHUB_ORG} target="_blank" rel="noreferrer">GitHub</a>
        <a href={AGENT_WORKFLOWS_REPO} target="_blank" rel="noreferrer">Agent workflows</a>
        <a href={GITHUB_SPONSOR} target="_blank" rel="noreferrer">Sponsor</a>
        <a href={SHAKACODE_URL} target="_blank" rel="noreferrer">ShakaCode</a>
      </div>
      <div class="footer-col">
        <h4>Get help</h4>
        <a href={SHAKACODE_CONTACT} target="_blank" rel="noreferrer">Contact</a>
        <a href={ROR_SUPPORT} target="_blank" rel="noreferrer">Community support</a>
        <a href={ROR_PRO} target="_blank" rel="noreferrer">React on Rails Pro</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 ShakaCode. This website is MIT-licensed.</span>
      <span style="font-family: var(--ff-mono); opacity: 0.7">
        build → test → prove → deploy 🤙
      </span>
    </div>
  </div>
</footer>
