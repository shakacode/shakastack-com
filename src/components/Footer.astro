---
import {
  projects,
  BOOK_A_CALL,
  SHAKACODE_URL,
  SHAKACODE_CONTACT,
  GITHUB_ORG,
  GITHUB_SPONSOR,
  ALL_DEMOS,
} from "../data/shaka";
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a class="brand" href="#top">
          <span class="mark">🤙</span>
          <span>ShakaStack</span>
        </a>
        <p class="footer-about">
          An open-source stack from ShakaCode for building, testing, proving,
          and deploying modern Rails&nbsp;+&nbsp;React applications.
        </p>
      </div>
      <div class="footer-col">
        <h4>Projects</h4>
        {projects.map((p) => (
          <a href={p.url} target="_blank" rel="noreferrer">{p.name}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Explore</h4>
        <a href="#stack">The Stack</a>
        <a href="#examples">Examples</a>
        <a href={ALL_DEMOS} target="_blank" rel="noreferrer">All demos</a>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <a href={GITHUB_ORG} target="_blank" rel="noreferrer">GitHub</a>
        <a href={GITHUB_SPONSOR} target="_blank" rel="noreferrer">Sponsor</a>
        <a href={SHAKACODE_URL} target="_blank" rel="noreferrer">ShakaCode</a>
      </div>
      <div class="footer-col">
        <h4>Get help</h4>
        <a href={SHAKACODE_CONTACT} target="_blank" rel="noreferrer">Contact</a>
        <a href={BOOK_A_CALL} target="_blank" rel="noreferrer">Book a call</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 ShakaCode. ShakaStack is open source.</span>
      <span style="font-family: var(--ff-mono); opacity: 0.7">
        build → test → prove → deploy 🤙
      </span>
    </div>
  </div>
</footer>
