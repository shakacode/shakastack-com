---
import Icon from "./Icon.astro";
import HeroStackCard from "./islands/HeroStackCard.tsx";
import {
  projects,
  popmenuEvidence,
  STARTER_DEMO,
  STARTER_REPO,
} from "../data/shaka";
---

<header class="hero" id="top">
  <div class="hero-sun"></div>
  <div class="hero-grain"></div>
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <span class="eyebrow hero-eyebrow">Ambitious AI building, with proof</span>
      <h1>Build ambitious Rails + React apps with AI. <span class="grad">Prove</span> every improvement.</h1>
      <p class="hero-sub">
        Give coding agents a public Rails 8 + React 19 foundation instead of a
        blank prompt. Use ShakaPerf to measure each optimization and keep only
        changes it proves faster and visually stable.
      </p>
      <div class="hero-actions">
        <a class="btn btn-white" href={STARTER_REPO} target="_blank" rel="noreferrer">
          Clone the starter <Icon name="arrowUR" />
        </a>
        <a class="btn btn-light" href={STARTER_DEMO} target="_blank" rel="noreferrer">
          View the live demo <Icon name="arrowUR" />
        </a>
      </div>
    </div>

    <div class="hero-visual">
      <HeroStackCard client:visible projects={projects} />
    </div>
  </div>
  <aside class="wrap hero-evidence" aria-labelledby="popmenu-evidence-title">
    <div class="hero-evidence-inner">
      <div class="hero-evidence-copy">
        <span class="hero-evidence-kicker">Documented outcome</span>
        <h2 id="popmenu-evidence-title">{popmenuEvidence.title}</h2>
        <p>{popmenuEvidence.context}</p>
      </div>
      <div class="hero-evidence-metrics">
        {
          popmenuEvidence.metrics.map(([value, label]) => (
            <div class="hero-evidence-stat">
              <b>{value}</b>
              <span>{label}</span>
            </div>
          ))
        }
      </div>
      <a
        class="hero-evidence-source"
        href={popmenuEvidence.sourceUrl}
        target="_blank"
        rel="noreferrer"
      >
        {popmenuEvidence.sourceLabel} <Icon name="arrowUR" />
      </a>
    </div>
  </aside>
  <svg class="hero-waves" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0 64 C 240 110 480 18 720 52 C 960 86 1200 24 1440 60 L1440 120 L0 120 Z"
      fill="oklch(0.985 0.008 85)"
      opacity="0.55"></path>
    <path
      d="M0 86 C 240 50 520 116 760 84 C 1010 52 1230 104 1440 78 L1440 120 L0 120 Z"
      fill="oklch(0.985 0.008 85)"></path>
  </svg>
</header>
