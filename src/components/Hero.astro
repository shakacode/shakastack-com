---
import Icon from "./Icon.astro";
import HeroStackCard from "./islands/HeroStackCard.tsx";
import { projects, BOOK_A_CALL, popmenuEvidence } from "../data/shaka";
---

<header class="hero" id="top">
  <div class="hero-sun"></div>
  <div class="hero-grain"></div>
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <span class="eyebrow hero-eyebrow">Open source at the core</span>
      <h1>Ship modern React in Rails - <span class="grad">fast</span>, and prove it.</h1>
      <p class="hero-sub">
        ShakaStack connects four open-source ShakaCode projects,
        source-available ShakaPerf, and an optional commercially licensed
        React on Rails Pro tier. Build, test, measure, and deploy without
        splitting Rails from a separate frontend app.
      </p>
      <div class="hero-actions">
        <a class="btn btn-white" href="#stack">
          Explore the stack <Icon name="arrow" />
        </a>
        <a class="btn btn-light" href={BOOK_A_CALL} target="_blank" rel="noreferrer">
          Book a free call
        </a>
      </div>
      <div class="hero-meta">
        <div class="stat"><b>4 OSS</b><span>plus source-available ShakaPerf</span></div>
        <div class="stat"><b>MIT</b><span>React on Rails core</span></div>
        <div class="stat"><b>Pro</b><span>optional RSC &amp; advanced rendering</span></div>
      </div>
    </div>

    <div class="hero-visual">
      <HeroStackCard client:visible projects={projects} />
    </div>
  </div>
  <aside class="wrap hero-evidence" aria-labelledby="popmenu-evidence-title">
    <div class="hero-evidence-inner">
      <div class="hero-evidence-copy">
        <span class="hero-evidence-kicker">Documented outcome</span>
        <h2 id="popmenu-evidence-title">{popmenuEvidence.title}</h2>
        <p>{popmenuEvidence.context}</p>
      </div>
      <div class="hero-evidence-metrics">
        {
          popmenuEvidence.metrics.map(([value, label]) => (
            <div class="hero-evidence-stat">
              <b>{value}</b>
              <span>{label}</span>
            </div>
          ))
        }
      </div>
      <a
        class="hero-evidence-source"
        href={popmenuEvidence.sourceUrl}
        target="_blank"
        rel="noreferrer"
      >
        {popmenuEvidence.sourceLabel} <Icon name="arrowUR" />
      </a>
    </div>
  </aside>
  <svg class="hero-waves" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0 64 C 240 110 480 18 720 52 C 960 86 1200 24 1440 60 L1440 120 L0 120 Z"
      fill="oklch(0.985 0.008 85)"
      opacity="0.55"></path>
    <path
      d="M0 86 C 240 50 520 116 760 84 C 1010 52 1230 104 1440 78 L1440 120 L0 120 Z"
      fill="oklch(0.985 0.008 85)"></path>
  </svg>
</header>
