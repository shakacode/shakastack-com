---
import Icon from "./Icon.astro";
import { guideStats, GITHUB_ORG, SHAKACODE_URL } from "../data/shaka";
---

<section class="section guide-sec" id="guide">
  <div class="wrap guide-grid">
    <div class="guide-copy reveal">
      <span class="eyebrow" style="color: oklch(0.88 0.06 48)">Your guide</span>
      <h2>Maintainers with a public track record.</h2>
      <p>
        ShakaCode has worked on Rails + React systems since 2011 and maintains
        projects with more than 23 million combined gem downloads. Try the
        software, read the source, and judge the work before you buy anything.
      </p>
      <div class="guide-actions">
        <a class="btn btn-white" href={GITHUB_ORG} target="_blank" rel="noreferrer">
          Explore the source <Icon name="arrowUR" />
        </a>
        <a class="link-arrow" style="color: #fff" href={SHAKACODE_URL} target="_blank" rel="noreferrer">
          About ShakaCode <Icon name="arrowUR" />
        </a>
      </div>
    </div>
    <div class="guide-stats reveal">
      {
        guideStats.map((stat) => (
          <div class="gstat">
            <b>{stat.value}</b>
            <span>{stat.label}</span>
            <a href={stat.sourceUrl} target="_blank" rel="noreferrer">
              {stat.sourceLabel} <Icon name="arrowUR" />
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
