---
import { GITHUB_MARK_PATH } from "../lib/iconPaths";

interface Props {
  width?: number | string;
  height?: number | string;
  class?: string;
}

const { width = 16, height = 16, class: className } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="currentColor"
  width={width}
  height={height}
  aria-hidden="true"
  class={className}
  set:html={GITHUB_MARK_PATH}
/>
