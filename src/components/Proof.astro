---
import Icon from "./Icon.astro";
import GitHubMark from "./GitHubMark.astro";
import {
  logos,
  starter,
  STARTER_REPO,
  STARTER_DEMO,
  STARTER_AGENTS_MD,
  TANSTACK_ROUTER_DOC,
  TANSTACK_QUERY_DOC,
} from "../data/shaka";
---

<section class="section proof">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The proof</span>
      <h2>Start from a working app, not a slide deck.</h2>
    </div>

    <div class="starter reveal">
      <div class="starter-copy">
        <h3>{starter.title}</h3>
        <p>{starter.blurb}</p>
        <p class="starter-guardrail">{starter.guardrail}</p>
        <div class="starter-actions">
          <a class="btn btn-accent" href={STARTER_REPO} target="_blank" rel="noreferrer">
            <GitHubMark width={16} height={16} /> Get the starter
          </a>
          <a class="btn btn-ghost" href={STARTER_DEMO} target="_blank" rel="noreferrer">
            Live demo <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={TANSTACK_ROUTER_DOC} target="_blank" rel="noreferrer">
            TanStack Router guide <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={TANSTACK_QUERY_DOC} target="_blank" rel="noreferrer">
            TanStack Query guide <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={STARTER_AGENTS_MD} target="_blank" rel="noreferrer">
            Read its AGENTS.md <Icon name="arrowUR" />
          </a>
        </div>
        <div class="starter-chips">
          {starter.stack.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </div>

    <div class="proof-trust-head reveal">
      <span class="eyebrow">Trusted in production</span>
      <h3>Shipping for teams large and small.</h3>
    </div>
    <div class="logos-row reveal">
      {logos.map((l) => <span class="logo-ph">{l}</span>)}
    </div>
    <div class="quote reveal">
      <div class="qmark">“</div>
      <blockquote>
        React on Rails lets us run React at scale inside Rails without the
        complexity of a separate frontend deployment - 97% Good LCP scores and
        80% faster hydration across our platform.
      </blockquote>
      <cite><b>Justis Blasco</b> · Popmenu</cite>
    </div>
  </div>
</section>
