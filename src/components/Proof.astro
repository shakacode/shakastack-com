---
import { logos } from "../data/shaka";
---

<section class="section proof">
  <div class="wrap">
    <div
      class="section-head reveal"
      style="max-width: none; margin-bottom: 30px; text-align: center"
    >
      <span class="eyebrow" style="justify-content: center; display: inline-flex">
        Trusted in production
      </span>
      <h2 style="margin-top: 16px">Shipping for teams large and small.</h2>
    </div>
    <div class="logos-row reveal">
      {logos.map((l) => <span class="logo-ph">{l}</span>)}
    </div>
    <div class="quote reveal">
      <div class="qmark">“</div>
      <blockquote>
        React on Rails lets us run React at scale inside Rails without the
        complexity of a separate frontend deployment — 97% Good LCP scores and
        80% faster hydration across our platform.
      </blockquote>
      <cite><b>Justis Blasco</b> · Popmenu</cite>
    </div>
  </div>
</section>
