---
import Icon from "./Icon.astro";
import GitHubMark from "./GitHubMark.astro";
import {
  starter,
  STARTER_REPO,
  STARTER_DEMO,
  STARTER_AGENTS_MD,
  TANSTACK_ROUTER_DOC,
  TANSTACK_QUERY_DOC,
  SHADCN_UI,
} from "../data/shaka";
---

<section class="section proof" id="starter">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">Start with the code</span>
      <h2>Clone the Rails + React starter.</h2>
      <p>
        Give an agent a working architecture, explicit guardrails, and examples
        it can extend. Or open the live deployment to see the result first.
      </p>
    </div>

    <div class="starter reveal">
      <div class="starter-copy">
        <h3>{starter.title}</h3>
        <p>{starter.blurb}</p>
        <p class="starter-guardrail">{starter.guardrail}</p>
        <div class="starter-actions">
          <a class="btn btn-accent" href={STARTER_REPO} target="_blank" rel="noreferrer">
            <GitHubMark width={16} height={16} /> Clone the starter
          </a>
          <a class="btn btn-ghost" href={STARTER_DEMO} target="_blank" rel="noreferrer">
            View the live demo <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={TANSTACK_ROUTER_DOC} target="_blank" rel="noreferrer">
            TanStack Router guide <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={TANSTACK_QUERY_DOC} target="_blank" rel="noreferrer">
            TanStack Query guide <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={SHADCN_UI} target="_blank" rel="noreferrer">
            shadcn/ui <Icon name="arrowUR" />
          </a>
          <a class="link-arrow" href={STARTER_AGENTS_MD} target="_blank" rel="noreferrer">
            Read its AGENTS.md <Icon name="arrowUR" />
          </a>
        </div>
        <div class="starter-chips">
          {starter.stack.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </div>

  </div>
</section>
