---
import { problems } from "../data/shaka";
---

<section class="section problem-sec" id="problem">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The problem</span>
      <h2>AI can write the code. How do you know it made the app better?</h2>
      <p>
        Ambitious changes cross rendering, data, bundles, browser behavior,
        and deployment. Without conventions and measurement, speed becomes
        guesswork.
      </p>
    </div>
    <div class="problem-grid reveal">
      {
        problems.map(([title, desc], i) => (
          <div class="problem-card">
            <span class="pc-n">0{i + 1}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
          </div>
        ))
      }
    </div>
    <p class="problem-philosophy reveal">
      Let agents move fast. Keep Rails in charge. Require proof before a
      performance change survives.
    </p>
  </div>
</section>
