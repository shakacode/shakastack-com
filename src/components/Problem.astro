---
import { problems } from "../data/shaka";
---

<section class="section problem-sec" id="problem">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="eyebrow">The problem</span>
      <h2>Getting maximum React performance from Rails takes too much work.</h2>
      <p>
        You chose Rails to ship quickly. Then modern React added bundling,
        rendering, testing, measurement, and deployment decisions that pull
        attention away from your product.
      </p>
    </div>
    <div class="problem-grid reveal">
      {
        problems.map(([title, desc], i) => (
          <div class="problem-card">
            <span class="pc-n">0{i + 1}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
          </div>
        ))
      }
    </div>
    <p class="problem-philosophy reveal">
      Keep Rails at the center. Add modern React one proven step at a time.
    </p>
  </div>
</section>
