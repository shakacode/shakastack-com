---
import Icon from "./Icon.astro";
import { ROR_PRO, SHAKACODE_CONTACT } from "../data/shaka";
---

<section class="cta">
  <div class="hero-grain"></div>
  <div class="wrap cta-inner">
    <span class="eyebrow hero-eyebrow" style="justify-content: center; display: inline-flex">
      Built by ShakaCode
    </span>
    <h2 style="margin-top: 18px">Build first. Talk when it’s useful.</h2>
    <p>
      The starter, demos, source, and docs are public. If advanced rendering or
      production help earns a place in your project, React on Rails Pro and the
      maintainers are there.
    </p>
    <div class="cta-actions">
      <a class="btn btn-white" href={ROR_PRO} target="_blank" rel="noreferrer">
        Explore React on Rails Pro <Icon name="arrowUR" />
      </a>
      <a class="link-arrow" href={SHAKACODE_CONTACT} target="_blank" rel="noreferrer" style="color: #fff">
        Contact the maintainers <Icon name="arrowUR" />
      </a>
    </div>
  </div>
</section>
